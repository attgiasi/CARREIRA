# Endereço público. Exemplo gratuito: apice.203-0-113-10.sslip.io
APICE_DOMAIN=

NODE_ENV=production
DATABASE_URL=file:/app/storage/jobs.sqlite
STORAGE_ROOT=/app/storage
DASHBOARD_PORT=8788
GMAIL_SYNC_INTERVAL_MINUTES=30
CAREER_HUNTER_USER_ID=1

# A primeira conta sempre pode ser criada. Depois, altere para true se quiser
# permitir cadastro público de outras pessoas.
ALLOW_PUBLIC_REGISTRATION=false

# Gere com: openssl rand -base64 48
ACCOUNT_VAULT_KEY=

# IA (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Busca Google (opcional)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Gmail OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GMAIL_REFRESH_TOKEN=
GOOGLE_CREDENTIALS_JSON=
GOOGLE_TOKEN_JSON=

GOOGLE_CALENDAR_ENABLED=false
